<!DOCTYPE html>
<!-- data-bs-theme set by inline script below before render -->
<html lang="{{ lang | default('en') }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta property="og:type" content="website" />
  <meta property="og:description" content="{{ img.get(lang, img.get('en', '')) }}" />
  <meta property="og:image" content="{{ meta.url }}/public/{{ img.orig }}" />
  <meta property="og:image:alt" content="{{ img.get(lang, img.get('en', '')) }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="{{ meta.url }}/public/{{ img.orig }}" />
  <title>{{ img.get(lang, img.get('en', img.orig)) }} | {{ meta.title }}</title>
  <!-- Set Bootstrap color theme before CSS loads to avoid flash -->
  <script>
    (function() {
      var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.setAttribute('data-bs-theme', dark ? 'dark' : 'light');
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        document.documentElement.setAttribute('data-bs-theme', e.matches ? 'dark' : 'light');
      });
    })();
  </script>
  <link rel="stylesheet" href="../bootstrap.min.css" />
  <style>
    body { font-family: Garamond, 'EB Garamond', serif; }
    .photo-container { text-align: center; }
    .photo-img { max-width: 100%; max-height: 85vh; object-fit: contain; }
    .nav-btn { font-size: 2rem; text-decoration: none; padding: 0.3em 0.6em; color: var(--bs-body-color); }
    .nav-btn:hover { background: rgba(128,128,128,0.2); border-radius: 4px; color: var(--bs-emphasis-color); }
    .caption { font-size: 1.1rem; margin-top: 0.5rem; }
    .caption-cs { font-style: italic; font-size: 0.95rem; color: var(--bs-secondary-color); }
    footer { border-top: 1px solid var(--bs-border-color); margin-top: 1rem; padding-top: 0.5rem; font-size: 0.8rem; color: var(--bs-secondary-color); }
    .exif-table { font-size: 0.82rem; color: var(--bs-secondary-color); margin-top: 0.6rem; }
    .exif-table td:first-child { padding-right: 0.6em; white-space: nowrap; }
    .exif-gps-links a { margin-right: 0.5em; font-size: 0.82rem; }
  </style>
</head>
<body>
<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <a href="../index.html" class="nav-btn" title="Back to album">&larr;</a>
    <span class="text-muted small">{{ pos + 1 }} / {{ total }}</span>
    <div>
      {% if prev_id is not none %}
      <a href="{{ prev_id }}.html" class="nav-btn" title="Previous">&laquo;</a>
      {% endif %}
      {% if next_id is not none %}
      <a href="{{ next_id }}.html" class="nav-btn" title="Next">&raquo;</a>
      {% endif %}
    </div>
  </div>

  <div class="photo-container">
    <img src="../public/{{ img.orig }}" alt="{{ img.get(lang, '') }}" class="photo-img" />
  </div>

  {% set en_caption = img.get('en', '') %}
  {% set cs_caption = img.get('cs', '') %}
  {% if en_caption and en_caption != 'TODO' %}
  <div class="caption text-center mt-2">{{ en_caption }}</div>
  {% endif %}
  {% if cs_caption and cs_caption != 'TODO' and cs_caption != en_caption %}
  <div class="caption-cs text-center">{{ cs_caption }}</div>
  {% endif %}

  {% if exif %}
  <div class="text-center">
    <table class="exif-table d-inline-block text-start">
      {% if exif.camera %}<tr><td>Camera</td><td>{{ exif.camera }}</td></tr>{% endif %}
      {% if exif.lens %}<tr><td>Lens</td><td>{{ exif.lens }}</td></tr>{% endif %}
      {% if exif.aperture %}<tr><td>Aperture</td><td>{{ exif.aperture }}</td></tr>{% endif %}
      {% if exif.focal_length %}<tr><td>Focal length</td><td>{{ exif.focal_length }}</td></tr>{% endif %}
      {% if exif.shutter %}<tr><td>Shutter</td><td>{{ exif.shutter }}</td></tr>{% endif %}
      {% if exif.iso %}<tr><td>ISO</td><td>{{ exif.iso }}</td></tr>{% endif %}
      {% if exif.exposure_bias %}<tr><td>Exp. bias</td><td>{{ exif.exposure_bias }}</td></tr>{% endif %}
      {% if exif.datetime %}<tr><td>Date</td><td>{{ exif.datetime }}</td></tr>{% endif %}
    </table>
    {% if exif.gps %}
    <div class="exif-gps-links mt-1">
      <a href="https://mapy.com/?q={{ '%.6f' | format(exif.gps.lat) }},{{ '%.6f' | format(exif.gps.lon) }}" target="_blank" rel="noopener">Mapy.com</a>
      <a href="https://www.openstreetmap.org/?mlat={{ '%.6f' | format(exif.gps.lat) }}&amp;mlon={{ '%.6f' | format(exif.gps.lon) }}&amp;zoom=15" target="_blank" rel="noopener">OpenStreetMap</a>
      <a href="https://www.openrailwaymap.org/?lat={{ '%.6f' | format(exif.gps.lat) }}&amp;lon={{ '%.6f' | format(exif.gps.lon) }}&amp;zoom=15" target="_blank" rel="noopener">OpenRailwayMap</a>
    </div>
    {% endif %}
  </div>
  {% endif %}

  <footer class="text-center">
    <p>{{ meta.author }} &mdash; <a href="mailto:photos@jmq.cz">Request full quality</a></p>
  </footer>
</div>

<script src="../bootstrap.bundle.min.js"></script>
<script>
  // Keyboard navigation
  document.addEventListener("keydown", function(e) {
    if (e.key === "ArrowLeft" || e.key === "ArrowRight") {
      {% if prev_id is not none %}
      if (e.key === "ArrowLeft") window.location.href = "{{ prev_id }}.html";
      {% endif %}
      {% if next_id is not none %}
      if (e.key === "ArrowRight") window.location.href = "{{ next_id }}.html";
      {% endif %}
    }
    if (e.key === "Escape") window.location.href = "../index.html";
  });

  // Swipe navigation
  var tsX = null;
  document.addEventListener("touchstart", function(e) { tsX = e.touches[0].clientX; });
  document.addEventListener("touchend", function(e) {
    if (tsX === null) return;
    var diff = e.changedTouches[0].clientX - tsX;
    if (Math.abs(diff) > 50) {
      {% if prev_id is not none %}
      if (diff > 0) window.location.href = "{{ prev_id }}.html";
      {% endif %}
      {% if next_id is not none %}
      if (diff < 0) window.location.href = "{{ next_id }}.html";
      {% endif %}
    }
    tsX = null;
  });
</script>
</body>
</html>
