  </style>
</head>
<body>
<div id="log">
  <button id="open-gimp">GIMP</button>
</div>
<div id="showfoto-block">
  <div id="showfoto-block-img">
    <div id="showfoto-left-cont">
      <a><button id="showfoto-left">&lt;</button></a>
    </div><img id="showfoto-img" class="showfoto-img-reduced" data-imgid="{{ img_id }}"><div id="showfoto-right-cont">
      <a><button id="showfoto-right">&gt;</button></a>
    </div>
  </div>
</div>
<div id="showfoto-title">
  <div class="editable-text" data-source="this_image.cs">meow</div>
  <div class="editable-text" data-source="this_image.en">meow</div>
</div>
<p id="showfoto-footer">Photo ID: <span id="showfoto-id">{{ img_id }}</span> | <a href="mailto:photos@jmq.cz">Send me an e-mail</a> to request a photo in full quality.</p>

<script>
  var log_div = document.getElementById("log")
  var img_container = document.getElementById("img-container")
  var img_element = document.getElementById("showfoto-img")
  var img_id = Number(img_element.dataset.imgid)

  var prev_a = document.getElementById("showfoto-left").parentNode
  var next_a = document.getElementById("showfoto-right").parentNode

  var editables = document.getElementsByClassName("editable-text")

  var index = {}
  var this_image = null
  var response_handler = null
  var socket = null

  function TN(m) {
    return document.createTextNode(m)
  }

  function EL(t) {
    return document.createElement(t)
  }

  function CL(e) {
    while (e.firstChild)
      e.removeChild(e.firstChild)
  }

  function logMsg(m) {
    console.log(m)
    var d = EL("div")
    d.appendChild(TN(m))
    log_div.appendChild(d)
  }

  function editableUpdate(e) {
    CL(e)
    e.appendChild(TN(e.dataset.text))
  }

  function editableSave(ev) {
    let inp = ev.target
    let e = inp.parentNode
    e.dataset.text = inp.value
    editableUpdate(e)
    sendIndexUpdate(e.dataset.source, e.dataset.text)
  }

  function editableKey(ev) { 
//    logMsg("editable!" + ev.key)
    if (ev.key == "Enter" && !ev.ctrlKey && !ev.shiftKey && !ev.altKey)
      return editableSave(ev)

    if (ev.key == "Escape")
      return editableUpdate(ev.target.parentNode)

    ev.stopPropagation()
  }

  function editableEdit(ev) {
    let e = ev.target
    CL(e)
    inp = EL("textarea")
    inp.type = "text"
    inp.value = e.dataset.text
    inp.addEventListener("keydown", editableKey)
    e.appendChild(inp)
    inp.focus()
  }

  for (let e of editables) {
    e.addEventListener("click", editableEdit)
  }

  function sSend(data, rhandler) {
    socket.send(JSON.stringify(data))
    response_handler = rhandler
  }

  function receiveIndex(data) {
    index = JSON.parse(data)

    if (img_id > 0)
      prev_a.href = "/single-" + (img_id - 1)

    if (img_id + 1 < index.images.length)
      next_a.href = "/single-" + (img_id + 1)

    index.this_image = index.images[img_id]
    img_element.src = "/img/orig-" + img_id

    for (elem of editables) {
      var loc = index
      for (spart of elem.dataset.source.split("."))
	loc = loc[spart]

      elem.dataset.text = loc
      editableUpdate(elem)
    }
  }

  function loadIndex() {
    sSend({
      "_": "index",
    }, receiveIndex)
  }

  function sendIndexUpdate(path, value) {
    ss = path.split(".")
    if (ss[0] == "this_image")
      path = [ "images", img_id ].concat(ss.slice(1))

    sSend({
      "_": "update",
      "path": path,
      "value": value,
    }, receiveIndex)
  }

  try {
    socket = new WebSocket("ws://{{ app.host }}/controller/")
    socket.onopen = function () {
      logMsg("Connection succesful")
      loadIndex()
    }
    socket.onerror = function () {
      logMsg("Connection failed. Reload to retry.")
    }
    socket.onmessage = function (m) {
      if (response_handler === null)
	logMsg("<" + m.data)
      else
      {
	response_handler(m.data)
	response_handler = null
      }
    }
  } catch (err) {
    logMsg("Connection failed: " + err + " Reload to retry.")
  }

  function prev_foto() {
    prev_a.click()
    /*
    if (!!overlay_prev.dataset.target)
    {
      console.log("target is", overlay_prev.dataset.target)
      showfoto_img(document.getElementById(overlay_prev.dataset.target))
    }
    */
  }

  function next_foto() {
    next_a.click()
    /*
    if (!!overlay_next.dataset.target)
    {
      console.log("target is", overlay_next.dataset.target)
      showfoto_img(document.getElementById(overlay_next.dataset.target))
    }
    */
  }

  function open_gimp() {
    sSend({ "_": "gimp", "id": img_id })
  }

  document.getElementById("open-gimp").addEventListener("click", open_gimp)

  function toggleDelete() {
    sSend({ "_": "toggle_delete", "id": img_id }, receiveIndex)
  }

  function dispatchKey(e) {
    console.log(e)

    if (e.ctrlKey && e.key == "g") {
      open_gimp()
    }

    if (e.altKey || e.ctrlKey || e.metaKey || e.shiftKey)
      return

    if (e.key === "Escape") {
      window.location.href = "/"
    }

    if (e.key === "Delete") {
      toggleDelete()
    }

    if (e.key === "+") {
      img_element.classList.remove("showfoto-img-reduced")
    }

    if (e.key === "-") {
      img_element.classList.add("showfoto-img-reduced")
    }

    if (e.key === "ArrowLeft") {
      prev_foto()
    }

    if (e.key === "ArrowRight") {
      next_foto()
    }
  }

  document.addEventListener("keydown", dispatchKey)

  var tsX = null;
  var tsY = null;

  function getTouches(e) {
    return e.touches ||             // browser API
	   e.originalEvent.touches; // jQuery
  }

  function touchStart(e) {
    const first = getTouches(e)[0]
    tsX = first.clientX
    tsY = first.clientY
  }

  function touchMove(e) {
    if (!tsX || !tsY) return

    const move = getTouches(e)[0]
    var difX = move.clientX - tsX
    var difY = move.clientY - tsY

    var absX = Math.abs(difX)
    var absY = Math.abs(difY)

    if (absX > absY*2)
    { // Certainly left-right
      if (difX < 0)
	showfoto_img(document.getElementById(overlay_next.dataset.target))
      else
	showfoto_img(document.getElementById(overlay_prev.dataset.target))
    }

    else if (absY > absX*2)
    {
      // Certainly up-down
      if (difY < 0)
	showfoto_img(document.getElementById(overlay_next.dataset.target))
      else
	showfoto_img(document.getElementById(overlay_prev.dataset.target))
    }
    
    tsX = null
    tsY = null
  }

  document.addEventListener("touchstart", touchStart, false)
  document.addEventListener("touchmove", touchMove, false)

</script>
</body>
</html>
