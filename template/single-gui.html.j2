<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="generator" content="pandoc" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="$og-prefix$index.html" />
  <meta property="og:description" content="$og-description$" />
  <meta property="og:site_name" content="Maria's photo dumps" />
  <meta property="og:image" content="$og-prefix$$og-image$" />
  <meta property="og:image:url" content="$og-prefix$$og-image$" />
  <meta property="og:image:alt" content="$og-image-alt$" />

  <meta name="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="$og-prefix$index.html">
  <meta name="twitter:title" content="$if(og-pagetitle)$$og-pagetitle$$else$$pagetitle$$endif$">
  <meta name="twitter:description" content="$og-description$">
  <meta name="twitter:image" content="$og-prefix$$og-image$">

  <title>E | {{ meta.title }}</title>
  <style>
html {
  line-height: 1.2;
  font-family: serif;
  font-size: 0.9em;
  color: black;
  background-color: white;
}
body {
  margin: 0 auto;
/*  margin-right: auto; */
  max-width: 76em;
  padding: 1em;
  padding-top: 0;
  hyphens: auto;
  overflow-wrap: break-word;
  text-rendering: optimizeLegibility;
  font-kerning: normal;
}
p {
  margin: 0.7em 0;
}
a {
  color: black;
}
a:visited {
  color: black;
}

#log {
  font-family: monospace;
  border: 1px solid black;
  position: absolute;
  left: 2em;
  top: 1em;
  padding: 0.6em;
}

/* Toolbar for action buttons, separate from the log output area */
#controls {
  position: absolute;
  right: 2em;
  top: 1em;
  padding: 0.6em;
}

#controls button {
  padding: 0.5em 1.5em;
}

/* GIMP versions side panel */
#gimp-versions {
  display: none;
  margin-top: 0.5em;
  border: 1px solid #999;
  padding: 0.4em;
  background: #f8f8f8;
}

#gimp-versions-title {
  font-size: 0.8em;
  color: #555;
  margin-bottom: 0.3em;
}

.gimp-version-entry {
  display: flex;
  align-items: center;
  gap: 0.4em;
  margin-bottom: 0.3em;
}

.gimp-version-entry img {
  max-width: 64px;
  max-height: 64px;
  border: 1px solid #ccc;
}

.gimp-version-entry button {
  padding: 0.2em 0.6em;
  font-size: 0.8em;
}

/* EXIF data panel */
#exif-panel {
  display: none;
  margin-top: 0.5em;
  border: 1px solid #999;
  padding: 0.4em;
  background: #f8f8f8;
  font-size: 0.8em;
  max-width: 18em;
  line-height: 1.4;
}

#exif-panel table {
  border-collapse: collapse;
  width: 100%;
}

#exif-panel td {
  padding: 0.1em 0.3em;
  vertical-align: top;
}

#exif-panel td:first-child {
  color: #555;
  white-space: nowrap;
  padding-right: 0.6em;
}

#exif-panel .exif-gps-links a {
  margin-right: 0.4em;
  font-size: 0.9em;
}

.editable-text:hover::after {
  content: " ✏️";
}

.editable-text input, .editable-text textarea {
  width: 76em;
  height: 5rem;
}

#showfoto-left-cont, #showfoto-right-cont {
  position: absolute;
  top: 0;
  /*  height: 100%;*/
  width: 0;
  z-index: 1;
  height: 100%;
}

#showfoto-left-cont {
  left: 0;
}

#showfoto-right-cont {
  right: 0;
}

#showfoto-left:hover, #showfoto-right:hover {
  background: rgba(0, 0, 0, 0.05);
  color: rgba(0, 0, 0, 0.8);
}

#showfoto-left, #showfoto-right {
  position: absolute;
  top: 0;
  font-size: 800%;
  font-weight: bold;
  border: none;
  width: 0.7em;
  height: 100%;
  padding: 0;
  background: rgba(0, 0, 0, 0);
  color: rgba(0, 0, 0, 0);
}

#showfoto-left {
  left: 0;
}

#showfoto-right {
  right: 0;
}

#showfoto-block-img {
  position: relative;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 0);
  width: fit-content;
  height: fit-content;
}

.showfoto-img-reduced {
  max-width: 100%;
  max-height: calc(100vh - 13em);
}

#showfoto-img {
  display: block;
  border: 2px solid black;
}

/* Deleted state: dim photo and show red border */
#showfoto-img.img-deleted {
  opacity: 0.3;
  border: 3px solid red;
}

#deleted-banner {
  display: none;
  background: #f88;
  color: #800;
  font-weight: bold;
  text-align: center;
  padding: 0.3em;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
}

#showfoto-title {
  display: block;
  position: absolute;
  bottom: 1.9em;
  left: 0;
  width: 100%;
  text-align: center;
/*  font-size: 80%;*/
  padding: 0.8em;
  margin: 0;
}

#showfoto-title div {
  padding: 0.8em;
  border-top: 1px solid black;
}

#showfoto-footer {
  display: block;
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  text-align: center;
  /*  font-size: 60%;*/
  padding-bottom: 0.2em;
  border-top: 1px solid black;
  margin: 0;
}

  </style>
</head>
<body>
<div id="deleted-banner">MARKED FOR DELETION</div>
<div id="log"></div>
<div id="controls">
  <button id="open-gimp">GIMP</button>
  <button id="btn-undelete" style="display:none">Undelete</button>
  <!-- GIMP versions panel: shows the original(s) when a mod is active -->
  <div id="gimp-versions">
    <div id="gimp-versions-title">Originals</div>
    <div id="gimp-versions-list"></div>
  </div>
  <!-- EXIF data panel -->
  <div id="exif-panel">
    <table id="exif-table"></table>
    <div id="exif-gps" class="exif-gps-links"></div>
  </div>
</div>
<div id="showfoto-block">
  <div id="showfoto-block-img">
    <div id="showfoto-left-cont">
      <a><button id="showfoto-left">&lt;</button></a>
    </div><img id="showfoto-img" class="showfoto-img-reduced" data-imgid="{{ img_id }}"><div id="showfoto-right-cont">
      <a><button id="showfoto-right">&gt;</button></a>
    </div>
  </div>
</div>
<div id="showfoto-title">
  <div class="editable-text" data-source="this_image.cs">meow</div>
  <div class="editable-text" data-source="this_image.en">meow</div>
</div>
<p id="showfoto-footer">Photo ID: <span id="showfoto-id">{{ img_id }}</span> | <a href="mailto:photos@jmq.cz">Send me an e-mail</a> to request a photo in full quality.</p>

<script>
  var log_div = document.getElementById("log")
  var img_container = document.getElementById("img-container")
  var img_element = document.getElementById("showfoto-img")
  var img_id = Number(img_element.dataset.imgid)

  var prev_a = document.getElementById("showfoto-left").parentNode
  var next_a = document.getElementById("showfoto-right").parentNode

  var editables = document.getElementsByClassName("editable-text")

  var index = {}
  var this_image = null
  var response_handler = null
  var after_update_queue = []
  var queue = []
  var socket = null

  function TN(m) {
    return document.createTextNode(m)
  }

  function EL(t) {
    return document.createElement(t)
  }

  function CL(e) {
    while (e.firstChild)
      e.removeChild(e.firstChild)
  }

  function logMsg(m) {
    console.log(m)
    var d = EL("div")
    d.appendChild(TN(m))
    log_div.appendChild(d)
  }

  function editableUpdate(e) {
    CL(e)
    e.appendChild(TN(e.dataset.text))
  }

  // Save inp's current value; safe to call even after inp was removed from DOM.
  function editableSave(inp) {
    logMsg("Saved")
    let e = inp.parentNode
    if (!e) return  // already detached (e.g. called from blur after cycling)
    e.dataset.text = inp.value
    editableUpdate(e)  // removes inp from DOM (inp.parentNode becomes null after this)
    sendIndexUpdate(e.dataset.source, e.dataset.text)
  }

  function editableKey(ev) {
    ev.stopPropagation()  // never let key events escape the editor
    let prnt = ev.target.parentNode  // capture before editableSave detaches textarea

//    logMsg("Pressed " + ev.key)

    if (ev.key == "Tab" && !ev.ctrlKey && !ev.altKey) {
      // Find the next (Tab) or previous (Shift+Tab) lang variant
      let all = Array.from(editables)
      let idx = all.indexOf(prnt)
      let target_idx = ev.shiftKey ? idx - 1 : idx + 1
      if (idx >= 0 && target_idx >= 0 && target_idx < all.length)
      {
	let next = all[target_idx]
	after_update_queue.push(() => { editableEdit({ target: next })})
      }

      ev.preventDefault()
      editableSave(ev.target)
      return
    }

    if (ev.key == "Enter" && ev.ctrlKey) {
      editableSave(ev.target)
      return
    }

    if (ev.key == "Escape") {
      // Discard edit
      editableUpdate(ev.target.parentNode)
      return
    }
  }

  function editableEdit(ev) {
    let e = ev.target
    // If already in edit mode, do nothing (prevents click-inside-textarea re-init)
    if (e.querySelector("textarea"))
      return
    CL(e)
    let inp = EL("textarea")
    inp.value = e.dataset.text
    inp.addEventListener("keydown", editableKey)
    // Clicks inside the textarea must not bubble up and re-trigger editableEdit
    inp.addEventListener("click", function(ev) { ev.stopPropagation() })
    e.appendChild(inp)
    inp.focus()

    // Save when focus leaves the textarea (clicking elsewhere)
    inp.addEventListener("blur", function() { editableSave(inp) })
  }

  for (let e of editables) {
    e.addEventListener("click", editableEdit)
  }

  function sSend(data, rhandler) {
    if (response_handler !== null) {
      queue.push({ "data": data, "handler": rhandler})
    }
    else
    {
      socket.send(JSON.stringify(data))
      response_handler = rhandler
    }
  }

  var deleted_banner = document.getElementById("deleted-banner")
  var btn_undelete = document.getElementById("btn-undelete")

  function updateDeletedState() {
    let deleted = !!(index.images[img_id] && index.images[img_id].deleted)
    if (deleted) {
      img_element.classList.add("img-deleted")
      deleted_banner.style.display = "block"
      btn_undelete.style.display = ""
    } else {
      img_element.classList.remove("img-deleted")
      deleted_banner.style.display = "none"
      btn_undelete.style.display = "none"
    }
  }

  // Update the GIMP versions side panel.
  // Shows a mini-thumbnail of the original with a Revert button when
  // the current image has active GIMP mods.
  function updateGimpVersions() {
    var panel = document.getElementById("gimp-versions")
    var list = document.getElementById("gimp-versions-list")
    CL(list)

    var mods = this_image && this_image.gimp_mods
    if (!mods || mods.length === 0) {
      panel.style.display = "none"
      return
    }

    panel.style.display = ""

    // Offer "Revert to original" — gimp_orig bypasses the mod redirect
    var entry = EL("div")
    entry.className = "gimp-version-entry"

    var thumb = EL("img")
    thumb.src = "/img/gimp_orig-" + img_id + "?v=" + Date.now()
    thumb.title = "Original"
    entry.appendChild(thumb)

    var btn = EL("button")
    btn.textContent = "Revert"
    btn.title = "Revert to original (remove GIMP edit)"
    btn.addEventListener("click", function() {
      sSend({ "_": "gimp_revert", "id": img_id }, receiveIndex)
    })
    entry.appendChild(btn)

    list.appendChild(entry)
  }

  // Fetch and display EXIF data for the current image.
  function loadExif() {
    sSend({ "_": "exif", "id": img_id }, function(data) {
      var exif = JSON.parse(data)
      var panel = document.getElementById("exif-panel")
      var tbl = document.getElementById("exif-table")
      var gpsDiv = document.getElementById("exif-gps")
      CL(tbl)
      CL(gpsDiv)

      // Ordered rows to display
      var rows = [
        ["Camera",    exif.camera],
        ["Lens",      exif.lens],
        ["Aperture",  exif.aperture],
        ["Shutter",   exif.shutter],
        ["ISO",       exif.iso],
        ["Focal",     exif.focal_length],
        ["Exp. bias", exif.exposure_bias],
        ["Date",      exif.datetime],
      ]

      var hasAny = false
      for (var r of rows) {
        if (!r[1]) continue
        hasAny = true
        var tr = EL("tr")
        var th = EL("td"); th.appendChild(TN(r[0])); tr.appendChild(th)
        var td = EL("td"); td.appendChild(TN(r[1])); tr.appendChild(td)
        tbl.appendChild(tr)
      }

      if (exif.gps) {
        hasAny = true
        var lat = exif.gps.lat.toFixed(6)
        var lon = exif.gps.lon.toFixed(6)
        var links = [
          ["Mapy.com",          "https://mapy.com/?q=" + lat + "," + lon],
          ["OpenStreetMap",     "https://www.openstreetmap.org/?mlat=" + lat + "&mlon=" + lon + "&zoom=15"],
          ["OpenRailwayMap",    "https://www.openrailwaymap.org/?lat=" + lat + "&lon=" + lon + "&zoom=15"],
        ]
        for (var lnk of links) {
          var a = EL("a")
          a.href = lnk[1]
          a.target = "_blank"
          a.rel = "noopener"
          a.appendChild(TN(lnk[0]))
          gpsDiv.appendChild(a)
        }
      }

      panel.style.display = hasAny ? "" : "none"
    })
  }

  function receiveIndex(data) {
    index = JSON.parse(data)

    if (img_id > 0)
      prev_a.href = "/single-" + (img_id - 1)

    if (img_id + 1 < index.images.length)
      next_a.href = "/single-" + (img_id + 1)

    index.this_image = index.images[img_id]
    this_image = index.this_image

    // Use a cache-busting param so the browser re-fetches after a GIMP edit
    img_element.src = "/img/orig-" + img_id + "?v=" + Date.now()

    updateDeletedState()
    updateGimpVersions()

    for (elem of editables) {
      var loc = index
      for (spart of elem.dataset.source.split("."))
	loc = loc[spart]

      elem.dataset.text = loc
      editableUpdate(elem)
    }

    let q = after_update_queue
    after_update_queue = []
    for (cb of q)
      cb()
  }

  function loadIndex() {
    sSend({
      "_": "index",
    }, receiveIndex)
  }

  function sendIndexUpdate(path, value) {
    ss = path.split(".")
    if (ss[0] == "this_image")
      path = [ "images", img_id ].concat(ss.slice(1))

    sSend({
      "_": "update",
      "path": path,
      "value": value,
    }, receiveIndex)
  }

  try {
    socket = new WebSocket("ws://{{ app.host }}/controller/")
    socket.onopen = function () {
      logMsg("Connection succesful")
      loadIndex()
      // Load EXIF after the index; queued automatically via sSend
      after_update_queue.push(loadExif)
    }
    socket.onerror = function () {
      logMsg("Connection failed. Reload to retry.")
    }
    socket.onmessage = function (m) {
      if (response_handler === null) {
	// Unsolicited message = broadcast from server (e.g. GIMP output detected)
	try {
	  receiveIndex(m.data)
	  // Reload EXIF in case the active image file changed (GIMP mod)
	  after_update_queue.push(loadExif)
	} catch(e) {
	  logMsg("<" + m.data)
	}
      } else
      {
	response_handler(m.data)
	response_handler = null

	if (queue.length > 0) {
	  next = queue.shift()
	  sSend(next.data, next.handler)
	}
      }
    }
  } catch (err) {
    logMsg("Connection failed: " + err + " Reload to retry.")
  }

  function prev_foto() {
    prev_a.click()
    /*
    if (!!overlay_prev.dataset.target)
    {
      console.log("target is", overlay_prev.dataset.target)
      showfoto_img(document.getElementById(overlay_prev.dataset.target))
    }
    */
  }

  function next_foto() {
    next_a.click()
    /*
    if (!!overlay_next.dataset.target)
    {
      console.log("target is", overlay_next.dataset.target)
      showfoto_img(document.getElementById(overlay_next.dataset.target))
    }
    */
  }

  function open_gimp() {
    sSend({ "_": "gimp", "id": img_id })
  }

  document.getElementById("open-gimp").addEventListener("click", open_gimp)
  document.getElementById("btn-undelete").addEventListener("click", toggleDelete)

  function toggleDelete() {
    sSend({ "_": "toggle_delete", "id": img_id }, receiveIndex)
  }

  function dispatchKey(e) {
    console.log(e)

    // Shift+G: open GIMP (before the modifier guard below)
    if (e.shiftKey && !e.ctrlKey && !e.altKey && !e.metaKey && e.key == "G") {
      open_gimp()
      return
    }

    if (e.altKey || e.ctrlKey || e.metaKey || e.shiftKey)
      return

    if ((e.key === "Enter") || (e.key === "Tab")) {
      e.stopPropagation()
      e.preventDefault()
      // Open description editor on first editable (CS description)
      if (editables.length > 0)
      {
        editableEdit({ target: editables[0] })
      }
      return
    }

    if (e.key === "Escape") {
      // Close any open description editor first; navigate only if none is open.
      // This also handles the case where the textarea exists but is not focused
      // (so editableKey never fires for it).
      let openEditor = document.querySelector(".editable-text textarea")
      if (openEditor)
        editableUpdate(openEditor.parentNode)
      else
        window.location.href = "/"
    }

    if (e.key === "Delete") {
      toggleDelete()
    }

    if (e.key === "+") {
      img_element.classList.remove("showfoto-img-reduced")
    }

    if (e.key === "-") {
      img_element.classList.add("showfoto-img-reduced")
    }

    if (e.key === "ArrowLeft") {
      prev_foto()
    }

    if (e.key === "ArrowRight") {
      next_foto()
    }
  }

  document.addEventListener("keydown", dispatchKey)

  var tsX = null;
  var tsY = null;

  function getTouches(e) {
    return e.touches ||             // browser API
	   e.originalEvent.touches; // jQuery
  }

  function touchStart(e) {
    const first = getTouches(e)[0]
    tsX = first.clientX
    tsY = first.clientY
  }

  function touchMove(e) {
    if (!tsX || !tsY) return

    const move = getTouches(e)[0]
    var difX = move.clientX - tsX
    var difY = move.clientY - tsY

    var absX = Math.abs(difX)
    var absY = Math.abs(difY)

    if (absX > absY*2)
    { // Certainly left-right
      if (difX < 0)
	showfoto_img(document.getElementById(overlay_next.dataset.target))
      else
	showfoto_img(document.getElementById(overlay_prev.dataset.target))
    }

    else if (absY > absX*2)
    {
      // Certainly up-down
      if (difY < 0)
	showfoto_img(document.getElementById(overlay_next.dataset.target))
      else
	showfoto_img(document.getElementById(overlay_prev.dataset.target))
    }
    
    tsX = null
    tsY = null
  }

  document.addEventListener("touchstart", touchStart, false)
  document.addEventListener("touchmove", touchMove, false)

</script>
</body>
</html>
