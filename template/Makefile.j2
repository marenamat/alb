# Generated by alb. Re-run 'alb generate' to update.
# Set RSYNC_DEST before running 'make install', e.g.:
#   make install RSYNC_DEST=user@server:/var/www/albums/{{ album_url }}/

RSYNC_DEST ?= {{ rsync_dest | default('') }}

.PHONY: install edit generate

generate:
	alb.py generate .

install: generate
	@if [ -z "$(RSYNC_DEST)" ]; then echo "Set RSYNC_DEST to deploy, e.g. user@server:/path/"; exit 1; fi
	rsync -avz --delete views/ $(RSYNC_DEST)

edit:
	alb.py gui .
