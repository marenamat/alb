{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(curl *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(python *)",
      "Update(Alb/*)",
      "Update(Alb/**)",
      "Update(Alb/**/*)"
